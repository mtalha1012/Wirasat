<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #0b101a;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wirasat.DashboardController">
    <padding>
        <Insets top="20" right="40" bottom="20" left="40"/>
    </padding>

    <Label text="Financial Dashboard" styleClass="page-title"/>

    <GridPane hgap="20" vgap="20">
        <VBox style="-fx-background-color: #1c2331; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #38bdf8; -fx-border-width: 0 0 0 4; -fx-border-radius: 10;" GridPane.columnIndex="0">
            <Label text="Gross Estate Value" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            <Label fx:id="grossEstateLabel" text="Rs 0" style="-fx-text-fill: #38bdf8; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox style="-fx-background-color: #1c2331; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #ef4444; -fx-border-width: 0 0 0 4; -fx-border-radius: 10;" GridPane.columnIndex="1">
            <Label text="Total Liabilities" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            <Label fx:id="liabilitiesLabel" text="Rs 0" style="-fx-text-fill: #ef4444; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
        
        <VBox style="-fx-background-color: #1c2331; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #f59e0b; -fx-border-width: 0 0 0 4; -fx-border-radius: 10;" GridPane.columnIndex="2">
            <Label text="Total Wasiyat (Will)" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            <Label fx:id="wasiyatLabel" text="Rs 0" style="-fx-text-fill: #f59e0b; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox style="-fx-background-color: #1c2331; -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #E2B93B; -fx-border-width: 0 0 0 4; -fx-border-radius: 10;" GridPane.columnIndex="3">
            <Label text="Net Distributable Estate" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
            <Label fx:id="netEstateLabel" text="Rs 0" style="-fx-text-fill: #E2B93B; -fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>
</VBox>
