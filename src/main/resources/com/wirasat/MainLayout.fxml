<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane stylesheets="@styles.css" styleClass="main-background" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.wirasat.MainController">

    <left>
        <VBox styleClass="sidebar" prefWidth="250" spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <HBox alignment="CENTER">
                <ImageView fitWidth="180" preserveRatio="true">
                    <Image url="@logo.png" />
                </ImageView>
            </HBox>
            <Region prefHeight="30" /> 
            
            <Button text="Dashboard" styleClass="nav-button, active-nav" onAction="#showDashboard"/>
            <Button text="Family Members" styleClass="nav-button" onAction="#showFamilyMembers"/>
            <Button text="Assets" styleClass="nav-button" onAction="#showAssets"/>
            <Button text="Liabilities" styleClass="nav-button" onAction="#showLiabilities"/>
            <Button text="Wasiyat (Will)" styleClass="nav-button" onAction="#showWasiyat"/>
            <Button text="Distribution" styleClass="nav-button" onAction="#showDistribution"/>
            <Button text="Heirs &amp; Relations" styleClass="nav-button" onAction="#showHeirsRelations"/>
            
            <Region VBox.vgrow="ALWAYS" /> 
            <VBox styleClass="quote-box">
                <Label text="لِلرِّجَالِ نَصِيبٌ مِّمَّا تَرَكَ الْوَالِدَانِ" styleClass="arabic-text"/>
                <Label text="- An-Nisa 4:7" styleClass="quote-text"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <!-- Dynamic content loads here -->
        </StackPane>
    </center>
</BorderPane>