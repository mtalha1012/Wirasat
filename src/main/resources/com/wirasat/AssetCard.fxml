<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.wirasat.CardController" 
      styleClass="asset-card" prefWidth="300" prefHeight="160" spacing="0">
    
    <Pane fx:id="topColorBand" prefHeight="5" style="-fx-background-color: #E2B93B;"/>
    
    <VBox padding="15" spacing="10" VBox.vgrow="ALWAYS">
        <HBox alignment="TOP_LEFT" spacing="10">
            <Label fx:id="titleLabel" text="Asset Title" styleClass="card-title" wrapText="true" HBox.hgrow="ALWAYS" prefWidth="180"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="categoryLabel" text="Category" styleClass="tag-category"/>
        </HBox>
        
        <Label fx:id="valueLabel" text="Rs 0.0" styleClass="card-value"/>
        
        <Region VBox.vgrow="ALWAYS"/>
        
        <HBox alignment="CENTER_LEFT" spacing="5">
            <Label text="Owner:" styleClass="card-owner-label"/>
            <Label fx:id="ownerLabel" text="Owner Name" styleClass="card-owner-name"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="SHAREABLE" styleClass="tag-status"/>
        </HBox>
    </VBox>
</VBox>